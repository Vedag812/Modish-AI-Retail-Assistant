# Retail Sales Agent System Environment Variables
# Copy this file to .env and fill in your actual values

# ============================================
# REQUIRED: Google AI Configuration
# ============================================
# Gemini API Key (Required)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ============================================
# REQUIRED: Firebase Configuration
# ============================================
# Firebase Service Account Path (Required)
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Place the JSON file in your project and set the path here
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ============================================
# OPTIONAL: Razorpay Payment Gateway
# ============================================
# Razorpay Credentials (Optional - for payment processing)
# Get your keys from: https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# ============================================
# Model Configuration
# ============================================
DEFAULT_MODEL=gemini-2.5-flash
MAX_RETRIES=3
RETRY_DELAY=1
